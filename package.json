{
  "name": "ide-shepherd-extension",
  "displayName": "ide-shepherd-extension",
  "description": "A security extension capable of realtime monitoring from within the IDE",
  "version": "2.0.1",
  "publisher": "datadog",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/IDE-Shepherd-extension"
  },
  "engines": {
    "vscode": "^1.99.3"
  },
  "categories": [
    "Other",
    "Security"
  ],
  "icon": "resources/icons/icon.png",
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ide-shepherd-explorer",
          "title": "IDE Shepherd",
          "icon": "resources/icons/shepherd.png"
        }
      ]
    },
    "views": {
      "ide-shepherd-explorer": [
        {
          "id": "ide-shepherd-status",
          "name": "Security Status",
          "when": "true",
          "contextualTitle": "IDE Shepherd Security Status"
        },
        {
          "id": "ide-shepherd-extensions",
          "name": "Extensions Analysis",
          "when": "true",
          "contextualTitle": "Extension Security Analysis"
        },
        {
          "id": "ide-shepherd-allowlist",
          "name": "Allow Lists",
          "when": "true",
          "contextualTitle": "Extension Allow Lists"
        },
        {
          "id": "ide-shepherd-events",
          "name": "Security Events",
          "when": "true",
          "contextualTitle": "Recent Security Events"
        },
        {
          "id": "ide-shepherd-task-timeline",
          "name": "Task Timeline",
          "when": "true",
          "contextualTitle": "Suspicious Tasks Timeline"
        },
        {
          "id": "ide-shepherd-settings",
          "name": "Settings",
          "when": "true",
          "contextualTitle": "IDE Shepherd Settings"
        }
      ]
    },
    "commands": [
      {
        "command": "ide-shepherd.showStatus",
        "title": "Show Security Status",
        "category": "IDE Shepherd",
        "icon": "$(info)"
      },
      {
        "command": "ide-shepherd.scanExtensions",
        "title": "Scan Extensions",
        "category": "IDE Shepherd",
        "icon": "$(search)"
      },
      {
        "command": "ide-shepherd.showEvents",
        "title": "Show Security Events",
        "category": "IDE Shepherd",
        "icon": "$(list-unordered)"
      },
      {
        "command": "ide-shepherd.refreshStatus",
        "title": "Refresh Status",
        "category": "IDE Shepherd",
        "icon": "$(refresh)"
      },
      {
        "command": "ide-shepherd.addToAllowList",
        "title": "Add Extension to Allow List",
        "category": "IDE Shepherd",
        "icon": "$(add)"
      },
      {
        "command": "ide-shepherd.removeFromAllowList",
        "title": "Remove Extension from Allow List",
        "category": "IDE Shepherd",
        "icon": "$(remove)"
      },
      {
        "command": "ide-shepherd.clearAllowList",
        "title": "Clear User Allow List",
        "category": "IDE Shepherd",
        "icon": "$(trash)"
      },
      {
        "command": "ide-shepherd.addTrustedPublisher",
        "title": "Add Trusted Publisher",
        "category": "IDE Shepherd",
        "icon": "$(briefcase)"
      },
      {
        "command": "ide-shepherd.removeTrustedPublisher",
        "title": "Remove Trusted Publisher",
        "category": "IDE Shepherd",
        "icon": "$(remove)"
      },
      {
        "command": "ide-shepherd.settings.refresh",
        "title": "Refresh Settings",
        "category": "IDE Shepherd",
        "icon": "$(refresh)"
      },
      {
        "command": "ide-shepherd.settings.toggleDatadogTelemetry",
        "title": "Toggle Datadog Telemetry",
        "category": "IDE Shepherd",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "ide-shepherd.clearTaskTimeline",
        "title": "Clear Task Timeline",
        "category": "IDE Shepherd",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ide-shepherd.refreshStatus",
          "when": "view == ide-shepherd-status",
          "group": "navigation"
        },
        {
          "command": "ide-shepherd.scanExtensions",
          "when": "view == ide-shepherd-extensions",
          "group": "navigation"
        },
        {
          "command": "ide-shepherd.addToAllowList",
          "when": "view == ide-shepherd-allowlist",
          "group": "navigation"
        },
        {
          "command": "ide-shepherd.addTrustedPublisher",
          "when": "view == ide-shepherd-allowlist",
          "group": "navigation"
        },
        {
          "command": "ide-shepherd.settings.refresh",
          "when": "view == ide-shepherd-settings",
          "group": "navigation"
        },
        {
          "command": "ide-shepherd.clearTaskTimeline",
          "when": "view == ide-shepherd-task-timeline",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "ide-shepherd.showStatus",
          "when": "true"
        },
        {
          "command": "ide-shepherd.scanExtensions",
          "when": "true"
        },
        {
          "command": "ide-shepherd.showEvents",
          "when": "true"
        },
        {
          "command": "ide-shepherd.addToAllowList",
          "when": "true"
        },
        {
          "command": "ide-shepherd.clearAllowList",
          "when": "true"
        },
        {
          "command": "ide-shepherd.settings.refresh",
          "when": "true"
        },
        {
          "command": "ide-shepherd.settings.toggleDatadogTelemetry",
          "when": "true"
        },
        {
          "command": "ide-shepherd.clearTaskTimeline",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "IDE Shepherd",
      "properties": {
        "ide-shepherd.isEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable IDE Shepherd security monitoring"
        },
        "ide-shepherd.autoScan": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan extensions on startup"
        },
        "ide-shepherd.notificationLevel": {
          "type": "string",
          "enum": [
            "all",
            "high",
            "critical",
            "none"
          ],
          "default": "high",
          "description": "Minimum security level for notifications"
        },
        "ide-shepherd.maxEvents": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum number of security events to keep"
        },
        "ide-shepherd.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show IDE Shepherd status in status bar"
        },
        "ide-shepherd.datadog.isEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Datadog telemetry integration (requires Datadog Agent)"
        },
        "ide-shepherd.datadog.agentPort": {
          "type": "number",
          "minimum": 1024,
          "maximum": 65535,
          "description": "Local Datadog Agent port for TCP log forwarding"
        }
      }
    },
    "keybindings": [
      {
        "command": "ide-shepherd.showStatus",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "true"
      },
      {
        "command": "ide-shepherd.scanExtensions",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "true"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.json\"",
    "typecheck": "tsc --noEmit",
    "test": "vscode-test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.9.2",
    "@types/sinon": "^21.0.0",
    "@types/sinon-chai": "^4.0.0",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^4.5.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "sinon": "^21.0.1",
    "sinon-chai": "^3.7.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  }
}
