{
  "name": "ide-shepherd-extension",
  "displayName": "ide-shepherd-extension",
  "description": "A security extension capable of realtime monitoring from within the IDE",
  "version": "0.0.1",
  "publisher": "datadog",
  "engines": {
    "vscode": "^1.99.3"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ide-shepherd.showStatus",
        "title": "Show Status",
        "category": "IDE Shepherd"
      },
      {
        "command": "ide-shepherd.showWelcome",
        "title": "Show Welcome & Help",
        "category": "IDE Shepherd"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.json\"",
    "typecheck": "tsc --noEmit",
    "test": "vscode-test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.99.3",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  }
}
